  "explain": {
    "terms": [
      "Creators are the people who build and maintain applications (models, workflows, reports, AI).",
      "Applications are independent business systems (e.g. CRM, HR, ERP, Compliance). Each application can have multiple UI portals.",
      "Users are unlimited on all plans. We do not charge per user.",
      "Environment is the runtime where your applications execute (compute + database + operational guarantees). Shared environments run on shared infrastructure with tenant isolation.",
      "Storage includes application data and platform-managed metadata."
    ],
    "creditsIntro": "Credits are used when the platform does work for you:",
    "creditsList": [
      "AI application and report generation",
      "Automation and background workflows",
      "Integrations, APIs, and scheduled jobs"
    ],
    "creditsRule": "If a human clicks it, it is included. If the system runs it for you, it uses credits.",
    "creditsNote": "Credits are not used for users accessing applications, UI portals, forms, pages, or standard CRUD actions."
  },
