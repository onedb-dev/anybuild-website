<div class="page-use-cases">
  <section class="hero">
    <div class="container">
      <div class="kicker">{{hero.kicker}}</div>
      <h1>{{{hero.headlineHtml}}}</h1>
      <p class="hero-copy">{{{hero.copyHtml}}}</p>
      <div class="cta-row">
        <a class="btn primary" href="demo.html">Book a demo</a>
        <a class="btn secondary" href="try.html">Try for free</a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="use-case-page-grid">
        {{#each cases}}
          <article class="use-case-page-card">
            <div class="use-case-num">{{num}}</div>
            <h2>{{title}}</h2>
            <p>{{copy}}</p>
            <ul class="use-case-outcomes">
              {{#each outcomes}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          </article>
        {{/each}}
      </div>
    </div>
  </section>

  {{> sectionCta sectionCta}}
</div>
