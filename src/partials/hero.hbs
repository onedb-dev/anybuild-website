<section class="hero">
  <div class="container">
    <div class="hero-intro">
      <div class="kicker">{{kicker}}</div>

      <h1>{{{headlineHtml}}}</h1>

      <div class="subtagline">{{subtagline}}</div>

      {{#each copyLines}}
        <p class="hero-copy">{{this}}</p>
      {{/each}}

      <div class="hero-tags" aria-label="Platform highlights">
        {{#each pills}}
          <span class="hero-tag">{{this}}</span>
        {{/each}}
      </div>
    </div>

    {{> heroCard}}
  </div>
</section>
