<div class="hero-card">
  <div class="window-bar">
    <span></span><span></span><span></span>
  </div>

  <div class="mock-top">
    <div class="mock-title">{{mock.title}}</div>
  </div>

  <div id="panel-ai">
    <div style="padding:14px;border-radius:16px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);">
      <textarea
        id="prompt-input"
        class="hero-prompt-input"
        placeholder="{{mock.promptPlaceholder}}"
        aria-required="true"
        aria-invalid="false"
        aria-describedby="hero-prompt-error"
        style="width:100%;height:140px;border-radius:10px;border:1px solid rgba(255,255,255,0.1);background:rgba(0,0,0,0.2);color:white;padding:10px;font-size:12px;resize:none;"
      ></textarea>
      <p id="hero-prompt-error" class="hero-prompt-error" hidden role="alert">Enter a prompt to continue.</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;margin-bottom:14px;">
        {{#each mock.examples}}
          <button type="button" class="pill example" data-full="{{full}}">{{label}}</button>
        {{/each}}
      </div>
      <div style="display:flex;justify-content:flex-end;align-items:center;margin-top:10px;">
        <button type="button" class="btn primary" id="hero-generate-ai" style="padding:8px 12px;font-size:12px;">Generate with AI</button>
      </div>
    </div>
  </div>


  <div class="flow" style="margin-top:20px;">
    {{#each flowSteps}}
      <div class="flow-step">
        <div class="step-num">{{num}}</div>
        <div>
          <div class="step-title">{{title}}</div>
          <div class="step-copy">{{copy}}</div>
        </div>
      </div>
    {{/each}}
  </div>
</div>
