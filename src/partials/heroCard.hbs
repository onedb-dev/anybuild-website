<div class="hero-mock">
  <div class="hero-mock-head">
    <h2 class="hero-mock-title">{{mock.title}}</h2>
  </div>

  <div id="panel-ai" class="hero-prompt-block">
    <textarea
      id="prompt-input"
      class="hero-prompt-input"
      placeholder="{{mock.promptPlaceholder}}"
      aria-required="true"
      aria-invalid="false"
      aria-describedby="hero-prompt-error"
    ></textarea>
    <p id="hero-prompt-error" class="hero-prompt-error" hidden role="alert">Enter a prompt to continue.</p>
    <div class="hero-examples">
      {{#each mock.examples}}
        <button type="button" class="pill example" data-full="{{full}}">{{label}}</button>
      {{/each}}
    </div>
    <div class="hero-prompt-actions">
      <button type="button" class="btn primary hero-prompt-btn" id="hero-generate-ai">Generate with AI</button>
    </div>
  </div>

  <div class="flow hero-flow">
    {{#each flowSteps}}
      <div class="flow-step">
        <div class="step-num">{{num}}</div>
        <div>
          <div class="step-title">{{title}}</div>
          <div class="step-copy">{{copy}}</div>
        </div>
      </div>
    {{/each}}
  </div>
</div>
