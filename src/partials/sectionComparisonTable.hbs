<section id="{{id}}">
  <div class="container">
    <div class="section-header">
      <div class="section-label">{{label}}</div>
      <h2>{{title}}</h2>
      <p class="section-copy">{{{copyHtml}}}</p>
    </div>

    <div class="comparison-table-wrap">
      <table class="comparison-table">
        <thead>
          <tr>
            {{#each columns}}
              <th scope="col"{{#if highlight}} class="is-highlight"{{/if}}>{{label}}</th>
            {{/each}}
          </tr>
        </thead>
        <tbody>
          {{#each rows}}
            <tr>
              <th scope="row">{{dimension}}</th>
              {{#each values}}
                <td>{{this}}</td>
              {{/each}}
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</section>
