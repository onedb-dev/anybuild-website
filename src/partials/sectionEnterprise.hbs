<section id="{{id}}">
  <div class="container">
    <div class="section-header">
      <div class="section-label">{{label}}</div>
      <h2>{{title}}</h2>
      <p class="section-copy">{{{copyHtml}}}</p>
    </div>

    <div class="enterprise-grid">
      <div class="enterprise-problems">
        <h3>{{problemsTitle}}</h3>
        <div class="enterprise-items">
          {{#each problems}}
            <div class="enterprise-item">
              <h4>{{title}}</h4>
              <p>{{copy}}</p>
            </div>
          {{/each}}
        </div>
      </div>
      <div class="enterprise-solutions">
        <h3>{{solutionsTitle}}</h3>
        <div class="enterprise-items">
          {{#each solutions}}
            <div class="enterprise-item">
              <h4>{{title}}</h4>
              <p>{{copy}}</p>
            </div>
          {{/each}}
        </div>
      </div>
    </div>

    <div class="use-case-grid">
      {{#each useCases}}
        <div class="use-case-card">
          <div class="use-case-num">{{num}}</div>
          <h4>{{title}}</h4>
          <p>{{copy}}</p>
        </div>
      {{/each}}
    </div>

    <p class="enterprise-more"><a href="use-cases.html">See all use cases →</a></p>
  </div>
</section>
