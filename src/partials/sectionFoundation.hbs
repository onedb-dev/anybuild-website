<section id="{{id}}">
  <div class="container">
    <div class="section-header">
      <div class="section-label">{{label}}</div>
      <h2>{{title}}</h2>
      <p class="section-copy">{{{copyHtml}}}</p>
    </div>

    <div class="platform">
      <div class="platform-main">
        <h3>{{main.title}}</h3>
        <p>{{main.intro}}</p>

        <div class="feature-list">
          {{#each main.features}}
            <div class="feature-row">
              <span>✓</span>
              <div><strong>{{title}}</strong>{{text}}</div>
            </div>
          {{/each}}
        </div>
      </div>

      <div class="side-stack">
        {{#each sideCards}}
          <div class="mini-card{{#if highlight}} highlight{{/if}}">
            <h4>{{title}}</h4>
            <p>{{{bodyHtml}}}</p>
          </div>
        {{/each}}
      </div>
    </div>
  </div>
</section>
